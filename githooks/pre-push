#!/bin/sh
# Incrémente le patch (1.0.0 → 1.0.1) et met à jour package.json + app-version.ts.
# Le hook re-pousse ensuite HEAD avec PIEML_SKIP_VERSION_BUMP=1.
# Git peut afficher une erreur sur le push d'origine : elle est normale (déjà poussé).
# Skip manuel : PIEML_SKIP_VERSION_BUMP=1 git push

if [ "$PIEML_SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

REMOTE="$1"

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

has_branch_push=0
while read -r local_ref local_sha remote_ref remote_sha
do
  case "$remote_ref" in
    refs/heads/*)
      if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
        has_branch_push=1
      fi
      ;;
  esac
done

if [ "$has_branch_push" -ne 1 ]; then
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  echo "pre-push: node est requis pour incrémenter la version" >&2
  exit 1
fi

VERSION="$(node scripts/bump-version.mjs)" || exit 1

git add package.json src/app/core/app-version.ts
if git diff --cached --quiet; then
  exit 0
fi

git commit -m "chore: bump version to ${VERSION}" >/dev/null 2>&1 || exit 1

echo "Version frontend incrémentée à ${VERSION} — envoi du commit de version..."
PIEML_SKIP_VERSION_BUMP=1 git push "$REMOTE" HEAD

# Annule le push d'origine (déjà effectué ci-dessus avec le bump)
exit 1
